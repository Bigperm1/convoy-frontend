{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "EXPO_PUBLIC_BACKEND_URL": "https://motorist-hub.preview.emergentagent.com"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "EXPO_PUBLIC_BACKEND_URL": "https://motorist-hub.preview.emergentagent.com"
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "env": {
        "_comment": "Replace EXPO_PUBLIC_BACKEND_URL with your Emergent .sh deployed URL after clicking Deploy.",
        "EXPO_PUBLIC_BACKEND_URL": "https://YOUR-CONVOY-APP.emergent.sh",
        "EXPO_PUBLIC_GOOGLE_MAPS_KEY": "$EXPO_PUBLIC_GOOGLE_MAPS_KEY",
        "EXPO_PUBLIC_SPOTIFY_CLIENT_ID": "$EXPO_PUBLIC_SPOTIFY_CLIENT_ID",
        "EXPO_PUBLIC_SUPABASE_URL": "$EXPO_PUBLIC_SUPABASE_URL",
        "EXPO_PUBLIC_SUPABASE_ANON_KEY": "$EXPO_PUBLIC_SUPABASE_ANON_KEY"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
