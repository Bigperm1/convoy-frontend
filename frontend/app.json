{
  "expo": {
    "name": "Convoy",
    "slug": "convoy",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/final_icon.png",
    "scheme": "convoy",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "runtimeVersion": "1.7.0",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sw0rdfisch.convoy",
      "buildNumber": "50",
      "config": {
        "googleMapsApiKey": "AIzaSyC0w5LHgZ1ud3EmeAhUkr4aOAOf89bE09U"
      },
      "infoPlist": {
        "NSAppleMusicUsageDescription": "Play and control Apple Music right inside Convoy",
        "NSLocationWhenInUseUsageDescription": "Show nearby drivers and hazards on the map",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Keep the convoy live in the background",
        "NSMicrophoneUsageDescription": "Push-to-talk and voice commands",
        "NSCameraUsageDescription": "Add photos of your car to your garage",
        "NSSpeechRecognitionUsageDescription": "Voice activation for hands-free driving",
        "UIBackgroundModes": [
          "audio",
          "location",
          "fetch"
        ],
        "ITSAppUsesNonExemptEncryption": false,
        "CADisableMinimumFrameDurationOnPhone": true
      }
    },
    "android": {
      "package": "com.sw0rdfisch.convoy",
      "versionCode": 50,
      "googleServicesFile": "./google-services.json",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyC0w5LHgZ1ud3EmeAhUkr4aOAOf89bE09U"
        }
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "POST_NOTIFICATIONS",
        "RECORD_AUDIO",
        "INTERNET"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "react-native-maps",
        {
          "iosGoogleMapsApiKey": "AIzaSyC0w5LHgZ1ud3EmeAhUkr4aOAOf89bE09U",
          "androidGoogleMapsApiKey": "AIzaSyC0w5LHgZ1ud3EmeAhUkr4aOAOf89bE09U"
        }
      ],
      [
        "expo-location",
        {
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true,
          "locationAlwaysAndWhenInUsePermission": "Keep navigation directions live in the background while a route is active."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/brand-mark.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/brand-mark.png",
          "color": "#2DEC86"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.0"
          },
          "android": {
            "minSdkVersion": 24,
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0"
          }
        }
      ],
      "./plugins/withConvoyAndroidAuto.js",
      "./plugins/withConvoyCarPlay.js"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1e72b32e-e0c5-4126-b590-ea2ec6e596e1"
      }
    },
    "owner": "sw0rdfisch",
    "updates": {
      "url": "https://u.expo.dev/1e72b32e-e0c5-4126-b590-ea2ec6e596e1"
    },
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    }
  }
}
